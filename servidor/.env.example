# =====================================================
# PLANTILLA DE VARIABLES DE ENTORNO
# =====================================================
# 1. Copia este archivo: cp .env.example .env
# 2. Completa los valores reales
# 3. NUNCA versiones el archivo .env en Git
# =====================================================

PORT=3000

# --- BASE DE DATOS LOCAL ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_contraseña_mysql
DB_NAME=inventario_libreria
# DB_SSL=false → local sin SSL  |  DB_SSL=true → nube con SSL (Aiven, etc.)
DB_SSL=false

# --- SEGURIDAD ---
# Genera una clave con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=clave_secreta_larga_y_aleatoria_aqui
# Duración de la sesión JWT (ej: 8h, 1d, 30m)
JWT_EXPIRY=8h

# --- ENTORNO ---
NODE_ENV=development

# --- CORS ---
CORS_ORIGIN=http://localhost:5173